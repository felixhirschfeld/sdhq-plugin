	},
	"homepage": "https://github.com/felixhirschfeld/sdhq-plugin#readme",
	"devDependencies": {
		"@decky/rollup": "^1.0.2",
		"@decky/ui": "^4.11.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/webpack": "^5.28.5",
		"rollup": "^4.59.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@decky/api": "^1.1.3",
